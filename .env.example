# Copy this file to ".env" and fill in the real values. Never commit ".env" to git.

SESSION_SECRET=replace-with-a-long-random-string
ADMIN_PASSWORD=replace-with-a-strong-password
STAFF_PASSWORD=replace-with-a-different-password-for-collections-staff

# ---- Xero (get these from https://developer.xero.com/app/manage ) ----
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/xero/callback
XERO_DEFAULT_ACCOUNT_CODE=200

PORT=3000
